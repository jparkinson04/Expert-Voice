---
---
<section class="tool-section" id="audit">
  <div class="container">
    <div class="tool-card reveal">
      <div>
        <span class="badge">Free • 10 minutes</span>
        <h2 class="display">The Founder Visibility Audit.</h2>
        <p>Seven questions. Instant personalised results. Find out exactly where your visibility is strong, where it's leaking, and what to fix first, without booking anything, paying anything, or sitting through a sales call.</p>
        <div class="tool-stats">
          <div class="tool-stat"><strong>7</strong><span>Quick questions</span></div>
          <div class="tool-stat"><strong>35</strong><span>Point score</span></div>
          <div class="tool-stat"><strong>3</strong><span>Fixes this week</span></div>
        </div>
        <a href="/audit" class="btn-primary">
          <span>Start the audit</span>
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </a>
      </div>
      <div class="audit-visual" aria-hidden="true">
        <div class="audit-header">
          <span>Your visibility score</span>
          <span>10 min</span>
        </div>
        <div class="score-circle">
          <div class="score-inner">
            <strong>25</strong>
            <span>/ 35</span>
          </div>
        </div>
        <div class="audit-bars">
          <div class="audit-bar">
            <span>Posting consistency</span>
            <div class="audit-bar-track">
              <div class="audit-bar-fill" style="--w: 0.8"></div>
            </div>
          </div>
          <div class="audit-bar">
            <span>ICP clarity</span>
            <div class="audit-bar-track">
              <div class="audit-bar-fill" style="--w: 0.5"></div>
            </div>
          </div>
          <div class="audit-bar">
            <span>Profile character</span>
            <div class="audit-bar-track">
              <div class="audit-bar-fill" style="--w: 0.9"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
