---
import { steps } from '../data/steps';
---
<section class="how-section" id="how">
  <div class="container">
    <div class="how-grid">
      <div class="how-intro reveal">
        <div class="section-label">How it works</div>
        <h2 class="display">A simple system you barely have to touch.</h2>
        <p>You're busy running the business. We built the process so your input is minimal, a few voice notes a month, and the output is consistent, on-brand content that compounds.</p>
        <a href="#book" class="btn-secondary">See the full process →</a>
      </div>

      <div class="steps">
        {steps.map((step, i) => (
          <div class="step reveal" data-delay={(i + 1).toString()}>
            <div class="step-num">{step.num}</div>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
