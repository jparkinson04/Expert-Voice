---
import { testimonials } from '../data/testimonials';
---
<section class="testimonials-section">
  <div class="container">
    <div class="section-label reveal">What clients say</div>
    <h2 class="display testimonials-headline reveal" data-delay="1">
      Words from the people <em>actually</em> using this.
    </h2>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class={`testimonial${t.featured ? ' featured' : ''} reveal`} data-delay={(i + 1).toString()}>
          <blockquote>
            {t.paragraphs.map((p) => <p>{p}</p>)}
          </blockquote>
          <div class="author">
            {t.logo ? (
              <div class="author-logo" aria-hidden="true">
                <img src={t.logo} alt="" loading="lazy" />
              </div>
            ) : (
              <div class="author-avatar" aria-hidden="true">{t.initials}</div>
            )}
            <div>
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
