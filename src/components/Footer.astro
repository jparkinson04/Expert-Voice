---
import { footerTagline, footerColumns, footerBottom } from '../data/footer';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="#" class="logo" aria-label="Expert Voice, home">
          <img src="/logo-full.png" alt="Expert Voice" class="logo-mark" width="136" height="72" />
        </a>
        <p class="footer-tagline">{footerTagline}</p>
      </div>
      {footerColumns.map((col) => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <div>{footerBottom.copyright}</div>
      <div>{footerBottom.made}</div>
    </div>
  </div>
</footer>
